<Window x:Class="FitnesInventory.AddEquipmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление оборудования" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Label Grid.Row="0" Grid.Column="0" Content="Название:"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtName" Margin="5"/>
        
        <Label Grid.Row="1" Grid.Column="0" Content="Серийный номер:"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtSerial" Margin="5"/>
        
        <Label Grid.Row="2" Grid.Column="0" Content="Категория:"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbCategory" 
                  DisplayMemberPath="CategoryName" Margin="5"/>
        
        <Label Grid.Row="3" Grid.Column="0" Content="Местоположение:"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbLocation" 
                  DisplayMemberPath="LocationName" Margin="5"/>
        
        <Label Grid.Row="4" Grid.Column="0" Content="Поставщик:"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbSupplier" 
                  DisplayMemberPath="SupplierName" Margin="5"/>
        
        <Label Grid.Row="5" Grid.Column="0" Content="Дата покупки:"/>
        <DatePicker Grid.Row="5" Grid.Column="1" x:Name="dpDate" Margin="5"/>
        
        <Label Grid.Row="6" Grid.Column="0" Content="Цена:"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtPrice" Margin="5"/>
        
        <Label Grid.Row="7" Grid.Column="0" Content="Статус:"/>
        <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cmbStatus" Margin="5">
            <ComboBoxItem Content="В наличии" IsSelected="True"/>
            <ComboBoxItem Content="В ремонте"/>
            <ComboBoxItem Content="Списано"/>
            <ComboBoxItem Content="Забронировано"/>
        </ComboBox>
        
        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="5">
            <Button x:Name="btnSave" Content="Сохранить" Width="80" Margin="5" 
                    Click="btnSave_Click" Background="LightGreen"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="80" Margin="5" 
                    Click="btnCancel_Click" Background="LightPink"/>
        </StackPanel>
    </Grid>
</Window>