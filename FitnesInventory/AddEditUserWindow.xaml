<Window x:Class="FitnesInventory.AddEditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь" Height="685" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Основная информация" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Логин:" Width="120" VerticalAlignment="Center"/>
            <TextBox x:Name="UsernameBox" Width="250"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Пароль:" Width="120" VerticalAlignment="Center"/>
            <PasswordBox x:Name="PasswordBox" Width="250"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="ФИО:" Width="120" VerticalAlignment="Center"/>
            <TextBox x:Name="FullNameBox" Width="250"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Роль:" Width="120" VerticalAlignment="Center"/>
            <ComboBox x:Name="RoleBox" Width="150">
                <ComboBoxItem Content="Пользователь"/>
                <ComboBoxItem Content="Администратор"/>
            </ComboBox>
        </StackPanel>

        <TextBlock Grid.Row="5" Text="Права доступа" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

        <GroupBox Grid.Row="6" Header="Оборудование" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="CanViewEquipmentCheck" Content="Просмотр" Width="100" Margin="10,5"/>
                <CheckBox x:Name="CanAddEquipmentCheck" Content="Добавление" Width="100" Margin="10,5"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="7" Header="Инвентарь" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="CanViewInventoryCheck" Content="Просмотр" Width="100" Margin="10,5"/>
                <CheckBox x:Name="CanAddInventoryCheck" Content="Добавление" Width="100" Margin="10,5"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="8" Header="Транзакции" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="CanViewTransactionsCheck" Content="Просмотр" Width="100" Margin="10,5"/>
                <CheckBox x:Name="CanAddTransactionsCheck" Content="Добавление" Width="100" Margin="10,5"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="9" Header="Сотрудники" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="CanViewEmployeesCheck" Content="Просмотр" Width="100" Margin="10,5"/>
                <CheckBox x:Name="CanAddEmployeesCheck" Content="Добавление" Width="100" Margin="10,5"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="10" Header="Поставщики и локации" Margin="0,0,0,15">
            <StackPanel>
                <CheckBox x:Name="CanViewSuppliersCheck" Content="Просмотр поставщиков" Margin="10,3"/>
                <CheckBox x:Name="CanAddSuppliersCheck" Content="Добавление поставщиков" Margin="10,3"/>
                <CheckBox x:Name="CanViewLocationsCheck" Content="Просмотр локаций" Margin="10,3"/>
                <CheckBox x:Name="CanAddLocationsCheck" Content="Добавление локаций" Margin="10,3"/>
                <CheckBox x:Name="CanViewCategoriesCheck" Content="Просмотр категорий" Margin="10,3"/>
                <CheckBox x:Name="CanAddCategoriesCheck" Content="Добавление категорий" Margin="10,3"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="100" Height="30" Margin="0,0,10,0" 
                    Background="LightGreen" Click="SaveBtn_Click"/>
            <Button Content="Отмена" Width="100" Height="30" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>